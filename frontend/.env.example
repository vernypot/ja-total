# Teofila — Supabase (required for dev and Netlify builds)
# Copy to .env for local development:
#   cp .env.example .env
#
# Netlify (Site configuration → Environment variables):
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_KEY
#   VITE_SITE_URL=https://teofila.netlify.app   (optional; recommended for production)
#
# Supabase Auth → URL configuration (production):
#   Site URL:        https://teofila.netlify.app
#   Redirect URLs:   https://teofila.netlify.app/**
#                    http://localhost:5173/**
#
# Use ONLY the anon / publishable key from Supabase → Project Settings → API.
# NEVER commit or deploy the service_role key in the frontend.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_KEY=your-anon-or-publishable-key
# VITE_SITE_URL=https://teofila.netlify.app
